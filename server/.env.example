# Server Configuration
PORT=5000
NODE_ENV=production

# PostgreSQL/Supabase Database
# Hodnoty získáš v Supabase dashboard → Settings → Database
DB_HOST=your-project.supabase.co
DB_USER=postgres
DB_PASSWORD=your-secure-password
DB_NAME=postgres
DB_PORT=5432

# JWT Secret - MUSÍ BÝT DLOUHÝ A BEZPEČNÝ!
# Například: $(openssl rand -base64 32)
JWT_SECRET=your-min-32-char-secret-key-generate-strong
