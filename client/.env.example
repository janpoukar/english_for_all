# Supabase Configuration
# Najdeš tyto hodnoty v Supabase: Project Settings → API

# Tvůj Supabase projekt URL
# Příklad: https://abc123xyz.supabase.co
REACT_APP_SUPABASE_URL=https://your-project.supabase.co

# Tvůj Supabase anon/public API Key
# Najdeš v: Settings → API → Project API keys → anon (public)
REACT_APP_SUPABASE_ANON_KEY=your-anon-key-here

# Backend URL (pokud používáš backend)
REACT_APP_API_URL=http://localhost:5000/api
